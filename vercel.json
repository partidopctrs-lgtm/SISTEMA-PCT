{
    "version": 2,
    "buildCommand": "npm run build",
    "outputDirectory": "public",
    "framework": "laravel",
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/build/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/index.php"
        }
    ]
}
